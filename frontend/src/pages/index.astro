---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactSection from "../components/ContactSection.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import PortfolioJourney from "../components/PortfolioJourney.astro";
import StoryHero from "../components/StoryHero.astro";
import { galleryItems } from "../data/site";

const seoTitle = "Atelie DebysArt | Bordados personalizados feitos a mao";
const seoDescription =
  "Landing page para encomendas de bordados personalizados, com exemplos de pecas, processo de atendimento e CTA direta para WhatsApp.";
---

<BaseLayout title={seoTitle} description={seoDescription} ogImage={galleryItems[8].image.src}>
  <Header />

  <main>
    <StoryHero />
    <PortfolioJourney />
    <ContactSection />
  </main>

  <Footer />
</BaseLayout>
