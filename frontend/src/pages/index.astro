---
import BaseLayout from "../layouts/BaseLayout.astro";
import About from "../components/About.astro";
import Differentials from "../components/Differentials.astro";
import FAQ from "../components/FAQ.astro";
import FinalCTA from "../components/FinalCTA.astro";
import Footer from "../components/Footer.astro";
import Gallery from "../components/Gallery.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Testimonials from "../components/Testimonials.astro";
import { galleryItems } from "../data/site";

const seoTitle = "Atelie DebysArt | Bordados personalizados feitos à mão";
const seoDescription =
  "Landing page premium para encomendas de bordados personalizados, com portfólio, processo de atendimento e CTA direta para WhatsApp.";
---

<BaseLayout title={seoTitle} description={seoDescription} ogImage={galleryItems[0].image.src}>
  <Header />

  <main>
    <Hero
      heroImage={galleryItems[0].image}
      supportingImage={galleryItems[3].image}
      detailImage={galleryItems[7].image}
    />
    <Gallery />
    <About />
    <HowItWorks />
    <Differentials />
    <Testimonials />
    <FAQ />
    <FinalCTA />
  </main>

  <Footer />
</BaseLayout>
