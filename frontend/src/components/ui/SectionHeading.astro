---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const { eyebrow, title, description, align = "left" } = Astro.props;
const isCentered = align === "center";
---

<div class:list={["max-w-3xl", isCentered && "mx-auto text-center"]}>
  <span class:list={["eyebrow", isCentered && "justify-center"]}>{eyebrow}</span>
  <h2 class="section-title">{title}</h2>
  {description && <p class="mt-6 max-w-2xl text-base leading-8 md:text-lg">{description}</p>}
</div>
