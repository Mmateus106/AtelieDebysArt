      d="M19.05 4.91A9.82 9.82 0 0 0 12.03 2C6.57 2 2.13 6.43 2.13 11.9c0 1.75.46 3.46 1.34 4.97L2 22l5.28-1.38a9.84 9.84 0 0 0 4.74 1.2h.01c5.46 0 9.9-4.43 9.9-9.9a9.84 9.84 0 0 0-2.88-7.01Zm-7.02 15.23h-.01a8.17 8.17 0 0 1-4.17-1.14l-.3-.18-3.13.82.84-3.05-.2-.31a8.16 8.16 0 0 1-1.26-4.37c0-4.5 3.66-8.16 8.16-8.16 2.18 0 4.23.84 5.76 2.39a8.09 8.09 0 0 1 2.39 5.78c0 4.5-3.66 8.16-8.08 8.16Zm4.47-6.09c-.24-.12-1.43-.7-1.65-.78-.22-.08-.38-.12-.54.12-.16.24-.62.78-.76.94-.14.16-.28.18-.52.06-.24-.12-1-.37-1.91-1.18-.71-.63-1.19-1.41-1.33-1.65-.14-.24-.01-.37.11-.49.11-.11.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.54-1.3-.74-1.78-.19-.46-.39-.4-.54-.41h-.46c-.16 0-.42.06-.64.3-.22.24-.84.82-.84 2s.86 2.32.98 2.48c.12.16 1.68 2.57 4.08 3.61.57.24 1.02.38 1.37.49.58.18 1.11.16 1.52.1.46-.07 1.43-.58 1.63-1.14.2-.56.2-1.04.14-1.14-.06-.1-.22-.16-.46-.28Z"
    />
