---
interface Props {
  href: string;
  label: string;
  variant?: "primary" | "secondary";
  fullWidth?: boolean;
}

const { href, label, variant = "primary", fullWidth = false } = Astro.props;
---

<a
  href={href}
  class:list={["cta-button", fullWidth && "w-full sm:w-auto"]}
  data-variant={variant === "secondary" ? "secondary" : undefined}
  target="_blank"
  rel="noreferrer"
  aria-label={label}
>
  <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5 fill-current">
