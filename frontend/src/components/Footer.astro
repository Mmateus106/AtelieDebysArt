---
import { brandName, whatsappUrl } from "../data/site";
---

<footer class="px-5 pb-10 pt-8 sm:px-6 lg:px-8">
  <div class="mx-auto flex max-w-7xl flex-col gap-4 border-t border-[rgba(143,101,88,0.14)] pt-6 text-sm text-[var(--text-soft)] sm:flex-row sm:items-center sm:justify-between">
    <p>{brandName}</p>
    <a href={whatsappUrl} target="_blank" rel="noreferrer" class="hover:text-[var(--text-main)]">
      Falar no WhatsApp
    </a>
  </div>
</footer>
