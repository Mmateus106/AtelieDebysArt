---
import { differentials } from "../data/site";
import SectionHeading from "./ui/SectionHeading.astro";
---

<section class="section-shell">
  <div class="mx-auto max-w-7xl">
    <SectionHeading
      eyebrow="Diferenciais"
      title="O valor do ateliê está no cuidado visível e no relacionamento que acompanha cada encomenda."
      description="Esses diferenciais ajudam a transformar o site em confiança e a confiança em conversas no WhatsApp."
    />

    <div class="mt-14 grid gap-5 md:grid-cols-2 xl:grid-cols-5">
      {differentials.map((item) => (
        <article class="glass-panel rounded-[2rem] p-6 md:p-7">
          <div class="mb-5 h-px w-14 bg-[rgba(143,99,86,0.34)]"></div>
          <h3 class="text-4xl text-[var(--text-main)]">{item.title}</h3>
          <p class="mt-4 text-sm leading-7 md:text-base">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
