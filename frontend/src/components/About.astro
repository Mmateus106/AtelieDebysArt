---
import { aboutContent } from "../data/site";
import SectionHeading from "./ui/SectionHeading.astro";
---

<section id="sobre" class="section-shell">
  <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.92fr_1.08fr]">
    <aside class="glass-panel relative overflow-hidden rounded-[2.5rem] p-8 md:p-10">
      <div class="absolute -left-8 top-10 h-28 w-28 rounded-full bg-[rgba(227,200,186,0.34)] blur-3xl"></div>
      <p class="eyebrow">Ateliê autoral</p>
      <p class="mt-8 text-4xl text-[var(--text-main)] md:text-5xl">{aboutContent.aside}</p>
    </aside>

    <div>
      <SectionHeading eyebrow={aboutContent.eyebrow} title={aboutContent.title} />
      <div class="mt-8 space-y-6 text-base leading-8 md:text-lg">
        {aboutContent.paragraphs.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>
    </div>
  </div>
</section>
