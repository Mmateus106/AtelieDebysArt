---
import { whatsappUrl } from "../data/site";
import WhatsAppButton from "./ui/WhatsAppButton.astro";
---

<section class="section-shell pt-10">
  <div class="mx-auto max-w-7xl">
    <div class="glass-panel relative overflow-hidden rounded-[2.8rem] px-6 py-12 sm:px-10 md:px-14 md:py-16">
      <div class="absolute -right-14 top-1/2 h-56 w-56 -translate-y-1/2 rounded-full bg-[rgba(227,200,186,0.4)] blur-3xl"></div>
      <div class="absolute -left-10 top-10 h-36 w-36 rounded-full bg-[rgba(143,99,86,0.12)] blur-3xl"></div>

      <div class="relative flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl">
          <span class="eyebrow">Faça sua encomenda</span>
          <h2 class="section-title">
            Se você já imaginou a peça, o próximo passo é começar a conversa.
          </h2>
          <p class="mt-6 max-w-2xl text-base leading-8 md:text-lg">
            Envie sua ideia pelo WhatsApp e receba um atendimento próximo para alinhar personalização,
            orçamento e prazo com leveza e clareza.
          </p>
        </div>

        <WhatsAppButton href={whatsappUrl} label="Pedir meu bordado personalizado" fullWidth />
      </div>
    </div>
  </div>
</section>
