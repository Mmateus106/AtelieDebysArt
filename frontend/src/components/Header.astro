---
import { brandName, navigationLinks, whatsappUrl } from "../data/site";
import WhatsAppButton from "./ui/WhatsAppButton.astro";
---

<header class="sticky top-0 z-40 px-4 pt-3 sm:px-6 lg:px-8">
  <div class="panel mx-auto flex max-w-7xl items-center justify-between rounded-full px-4 py-2.5 sm:px-5">
    <a href="#inicio" class="flex items-center gap-3 text-[0.82rem] font-semibold uppercase tracking-[0.14em] text-[var(--accent-deep)]">
      <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-[rgba(143,101,88,0.14)] text-lg font-semibold">
        D
      </span>
      <span class="hidden sm:inline">{brandName}</span>
    </a>

    <nav aria-label="Navegacao principal" class="hidden items-center gap-6 lg:flex">
      {navigationLinks.map((item) => (
        <a href={item.href} class="text-[0.95rem] text-[var(--text-soft)] hover:text-[var(--text-main)]">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden sm:block">
      <WhatsAppButton href={whatsappUrl} label="Chamar no WhatsApp" variant="secondary" />
    </div>
  </div>
</header>
