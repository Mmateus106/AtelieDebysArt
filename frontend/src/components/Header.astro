---
import { brandName, navigationLinks, whatsappUrl } from "../data/site";
import WhatsAppButton from "./ui/WhatsAppButton.astro";
---

<header class="sticky top-0 z-40 px-4 pt-4 sm:px-6 lg:px-8">
  <div class="glass-panel mx-auto flex max-w-7xl items-center justify-between rounded-full px-4 py-3 sm:px-6">
    <a href="#top" class="flex items-center gap-3 text-sm font-semibold tracking-[0.16em] text-[var(--accent-deep)] uppercase">
      <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-[rgba(143,99,86,0.14)] text-xl font-semibold">
        D
      </span>
      <span class="hidden sm:inline">{brandName}</span>
    </a>

    <nav aria-label="Navegação principal" class="hidden items-center gap-7 lg:flex">
      {navigationLinks.map((item) => (
        <a href={item.href} class="text-sm text-[var(--text-soft)] hover:text-[var(--text-main)]">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden sm:block">
      <WhatsAppButton href={whatsappUrl} label="Pedir orçamento" variant="secondary" />
    </div>
  </div>
</header>
