---
import { faqs } from "../data/site";
import SectionHeading from "./ui/SectionHeading.astro";
---

<section id="faq" class="section-shell">
  <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.8fr_1.2fr]">
    <div>
      <SectionHeading
        eyebrow="FAQ"
        title="Respostas claras para reduzir objeções e facilitar o primeiro contato."
        description="Uma boa landing premium também antecipa dúvidas, sem ficar carregada nem comercial demais."
      />
    </div>

    <div class="space-y-4">
      {faqs.map((item, index) => (
        <details class="faq-item glass-panel rounded-[1.75rem] px-6 py-5" open={index === 0}>
          <summary class="cursor-pointer list-none pr-8 text-xl text-[var(--text-main)] marker:hidden">
            {item.question}
          </summary>
          <p class="mt-4 max-w-2xl text-sm leading-7 md:text-base">{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>
