---
import { contactSection, whatsappUrl } from "../data/site";
import WhatsAppButton from "./ui/WhatsAppButton.astro";
---

<section id="contato" class="section-shell pt-8">
  <div class="panel mx-auto max-w-7xl overflow-hidden rounded-[2.5rem] px-6 py-12 sm:px-10 md:px-14 md:py-16">
    <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-end">
      <div class="max-w-3xl">
        <span class="eyebrow">{contactSection.eyebrow}</span>
        <h2 class="section-title mt-6">{contactSection.title}</h2>
        <p class="mt-6 max-w-2xl text-lg leading-8">{contactSection.description}</p>
      </div>

      <div class="soft-panel rounded-[2rem] p-6 sm:p-8">
        <p class="text-sm uppercase tracking-[0.24em] text-[var(--accent-deep)]">Pedido personalizado</p>
        <p class="mt-4 text-3xl text-[var(--text-main)]">
          Clique no botao abaixo para enviar sua referencia e iniciar o atendimento.
        </p>
        <div class="mt-8">
          <WhatsAppButton href={whatsappUrl} label="Abrir conversa no WhatsApp" fullWidth />
        </div>
      </div>
    </div>
  </div>
</section>
